<clickhouse>
    <logger>
        <level>warning</level>
        <log>/var/log/clickhouse-server/clickhouse-server.log</log>
        <errorlog>/var/log/clickhouse-server/clickhouse-server.err.log</errorlog>
        <size>10M</size>
        <count>3</count>
    </logger>

    <!-- Disable system log tables that grow unboundedly -->
    <text_log>
        <level>none</level>
        <ttl>EVENT DATE + INTERVAL 3 DAY</ttl>
    </text_log>
    <metric_log>
        <ttl>EVENT DATE + INTERVAL 7 DAY</ttl>
    </metric_log>
    <asynchronous_metric_log>
        <ttl>EVENT DATE + INTERVAL 7 DAY</ttl>
    </asynchronous_metric_log>
    <query_log>
        <ttl>EVENT DATE + INTERVAL 7 DAY</ttl>
    </query_log>
    <query_metric_log>
        <ttl>EVENT DATE + INTERVAL 7 DAY</ttl>
    </query_metric_log>
    <part_log>
        <ttl>EVENT DATE + INTERVAL 7 DAY</ttl>
    </part_log>
    <trace_log>
        <ttl>EVENT DATE + INTERVAL 7 DAY</ttl>
    </trace_log>
    <processors_profile_log>
        <ttl>EVENT DATE + INTERVAL 7 DAY</ttl>
    </processors_profile_log>
    <error_log>
        <ttl>EVENT DATE + INTERVAL 7 DAY</ttl>
    </error_log>
    <asynchronous_insert_log>
        <ttl>EVENT DATE + INTERVAL 7 DAY</ttl>
    </asynchronous_insert_log>
</clickhouse>
